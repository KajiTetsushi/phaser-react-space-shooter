{
    "name": "template-react-ts",
    "description": "A Phaser 3 TypeScript project template that demonstrates React communication and uses Vite for bundling.",
    "version": "1.1.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/phaserjs/template-react-ts.git"
    },
    "author": "Phaser Studio <support@phaser.io> (https://phaser.io/)",
    "license": "MIT",
    "licenseUrl": "http://www.opensource.org/licenses/mit-license.php",
    "bugs": {
        "url": "https://github.com/phaserjs/template-react-ts/issues"
    },
    "homepage": "https://github.com/phaserjs/template-react-ts#readme",
    "keywords": [
        "phaser",
        "phaser3",
        "eventemitter3",
        "react",
        "vite",
        "typescript"
    ],
    "scripts": {
        "dev": "node gryzor.js dev & vite --config vite/config.dev.ts",
        "build": "node gryzor.js build & vite build --config vite/config.prod.ts",
        "dev-nolog": "vite --config vite/config.dev.ts",
        "build-nolog": "vite build --config vite/config.prod.ts"
    },
    "dependencies": {
        "eventemitter3": "^5.0.4",
        "phaser": "3.90.0",
        "react": "19.2.4",
        "react-dom": "19.2.4"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.7",
        "@types/node": "25.5.0",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "6.0.1",
        "globals": "17.4.0",
        "terser": "5.46.0",
        "typescript": "5.9.3",
        "vite": "8.0.0"
    }
}